              "\r",
              "pm.test(\"CSRF-TOKEN cookie exists\", function () {\r",
              "    const csrfCookie = pm.cookies.get(\"CSRF-TOKEN\");\r",
              "    pm.expect(csrfCookie).to.not.be.undefined;\r",
