      "name": "GET - Login Page",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const csrfCookie = pm.cookies.get('CSRF-TOKEN');\r",
              "console.log('GET Login Page - CSRF cookie:', csrfCookie);\r",
              "if (csrfCookie) {\r",
              "    pm.environment.set('csrfToken', csrfCookie);\r",
              "    console.log('csrfToken guardado en environment');\r",
              "} else {\r",
              "    console.log('No se encontró CSRF-TOKEN en GET - Login Page');\r",
              "}\r",
              "\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
